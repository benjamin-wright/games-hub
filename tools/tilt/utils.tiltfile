# tools/tilt/utils.tiltfile — shared Tilt utility functions
#
# Load individual symbols into any Tiltfile with:
#   load("../../tools/tilt/utils.tiltfile", "namespace_create")
# (adjust the relative path to match the calling Tiltfile's location)

def namespace_create(name):
    """Emit a Kubernetes Namespace manifest so Tilt creates it if absent."""
    k8s_yaml(blob("""
apiVersion: v1
kind: Namespace
metadata:
  name: {}
""".format(name)))
